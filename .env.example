# pg-stig-audit Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ─── Wiz API Credentials ──────────────────────────────────────────────────────
# Create a Service Account in Wiz:
#   Settings → Service Accounts → Add Service Account
#   Scopes required:
#     - Issues: Read, Write
#     - Security Policies (Controls): Read, Write
#   Generate a Client Secret after creating the account.

WIZ_CLIENT_ID=your-wiz-client-id-here
WIZ_CLIENT_SECRET=your-wiz-client-secret-here

# Wiz API endpoint — use the one matching your Wiz tenant region:
#   US:  https://api.us1.app.wiz.io/graphql
#   EU:  https://api.eu1.app.wiz.io/graphql
WIZ_API_ENDPOINT=https://api.us1.app.wiz.io/graphql

# Optional: Wiz Project ID to scope issues to a specific project
# Find it in Wiz: Projects → select your project → copy the ID from URL
WIZ_PROJECT_ID=

# ─── GCP Security Command Center ──────────────────────────────────────────────
# Only needed if you use --scc output or push_to_scc.py.
# Authenticate via: gcloud auth application-default login
# Or set this to a service account key file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

GCP_PROJECT_ID=your-gcp-project-id
GCP_SCC_SOURCE=organizations/YOUR_ORG_ID/sources/YOUR_SOURCE_ID

# ─── PostgreSQL Credentials (direct mode) ─────────────────────────────────────
# Used when running: python3 audit.py --mode direct
# Docker and kubectl modes don't need a password here
# (Docker uses the container's local socket; kubectl uses the pod's)

PGPASSWORD=your-postgres-password

# ─── Optional Overrides ───────────────────────────────────────────────────────
# These match the CLI flags and can be used to set defaults:
# PGUSER=postgres
# PGDATABASE=postgres
# PGHOST=127.0.0.1
# PGPORT=5432
